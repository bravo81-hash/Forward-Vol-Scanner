{
  "name": "Forward Vol Scanner",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "postCreateCommand": "python -m pip install -r requirements.txt",
  "forwardPorts": [8765],
  "portsAttributes": {
    "8765": {
      "label": "Stock Opportunity Radar",
      "onAutoForward": "openBrowser"
    }
  },
  "containerEnv": {
    "FVS_WEB_HOST": "0.0.0.0",
    "FVS_WEB_PORT": "8765",
    "FVS_RADAR_AUTOSCAN": "0"
  }
}
